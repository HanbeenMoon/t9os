#!/bin/bash
# HWP 변환 래퍼 — WSL에서 Windows Python 호출
# Usage:
#   hwp input.hwp              → DOCX로 변환
#   hwp input.docx             → HWP로 변환
#   hwp input.hwp --pdf        → PDF로 변환
#   hwp ./folder/ --to docx    → 폴더 일괄 변환

WIN_PYTHON="${WIN_PYTHON:-/mnt/c/Python/python.exe}"
SCRIPT="$(cd "$(dirname "$0")" && pwd)/hwp_convert.py"

# WSL 경로 → Windows 경로 변환
convert_args() {
    local args=()
    for arg in "$@"; do
        if [[ -e "$arg" ]] || [[ "$arg" == /mnt/* ]]; then
            args+=("$(wslpath -w "$arg" 2>/dev/null || echo "$arg")")
        else
            args+=("$arg")
        fi
    done
    echo "${args[@]}"
}

if [ $# -eq 0 ]; then
    echo "Usage: hwp <file.hwp|file.docx|folder/> [--pdf] [--to docx|hwp|pdf] [-o output]"
    exit 1
fi

WIN_SCRIPT="$(wslpath -w "$SCRIPT")"
CONVERTED_ARGS=$(convert_args "$@")

"$WIN_PYTHON" "$WIN_SCRIPT" $CONVERTED_ARGS
